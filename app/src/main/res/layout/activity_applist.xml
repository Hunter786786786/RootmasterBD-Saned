<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#050A0F">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
        <TextView android:id="@+id/tvAppListTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="App Mode Assignment"
            android:textColor="#00B4FF" android:textSize="16sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnSaveApps" android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="SAVE" android:textColor="#000000" android:background="#00FF88" android:textSize="12sp"/>
    </LinearLayout>
    <EditText android:id="@+id/etSearch" android:layout_width="match_parent" android:layout_height="44dp"
        android:hint="Search apps..." android:textColorHint="#405060" android:textColor="#D0E8FF"
        android:background="#080E18" android:paddingStart="12dp" android:paddingEnd="12dp"
        android:inputType="text" android:layout_marginTop="4dp"/>
    <ScrollView android:id="@+id/scrollApps" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:id="@+id/appListContainer" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
