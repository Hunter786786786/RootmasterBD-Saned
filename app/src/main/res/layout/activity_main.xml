<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#050A0F">

    <!-- TOP BAR -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A1628" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="BGGuard" android:textColor="#00B4FF" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvMode" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="[BALANCED]" android:textColor="#00FF88" android:textSize="13sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- MODE BUTTONS -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:layout_marginTop="8dp" android:paddingStart="8dp" android:paddingEnd="8dp">
        <Button android:id="@+id/btnBalanced" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="4dp" android:text="BALANCED"
            android:textSize="11sp" android:textStyle="bold" android:background="#0A1628" android:textColor="#00FF88"/>
        <Button android:id="@+id/btnPerformance" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="4dp" android:text="PERFORMANCE"
            android:textSize="11sp" android:textStyle="bold" android:background="#0A1628" android:textColor="#00B4FF"/>
        <Button android:id="@+id/btnGaming" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="GAMING"
            android:textSize="11sp" android:textStyle="bold" android:background="#0A1628" android:textColor="#FF8C00"/>
    </LinearLayout>

    <!-- MAIN CONTENT SCROLL -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginTop="6dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingStart="8dp" android:paddingEnd="8dp">

            <!-- PERFORMANCE CARD -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#080E18" android:padding="12dp" android:orientation="vertical" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PERFORMANCE" android:textColor="#4070A0" android:textSize="10sp" android:letterSpacing="0.15"/>
                <TextView android:id="@+id/tvOryon" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Oryon: ---" android:textColor="#FFD700" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tvCpu" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="CPU: ---" android:textColor="#90B8D8" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvGpu" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="GPU: ---" android:textColor="#90B8D8" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:id="@+id/tvRefresh" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="---Hz" android:textColor="#90B8D8" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvFps" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="FPS: ---" android:textColor="#90B8D8" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:id="@+id/tvIface" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="IF: ---" android:textColor="#405060" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvUid" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="UID: ---" android:textColor="#405060" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- APPS CARD -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#080E18" android:padding="12dp" android:orientation="vertical" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TARGET APPS" android:textColor="#4070A0" android:textSize="10sp" android:letterSpacing="0.15"/>
                <TextView android:id="@+id/tvJahez" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Jahez: ---" android:textColor="#90B8D8" android:textSize="13sp" android:layout_marginTop="4dp"/>
                <TextView android:id="@+id/tvSaned" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Saned: ---" android:textColor="#90B8D8" android:textSize="13sp"/>
                <TextView android:id="@+id/tvMaps" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Maps: ---" android:textColor="#90B8D8" android:textSize="13sp"/>
            </LinearLayout>

            <!-- NETWORK CARD -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#080E18" android:padding="12dp" android:orientation="vertical" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="NETWORK" android:textColor="#4070A0" android:textSize="10sp" android:letterSpacing="0.15"/>
                <TextView android:id="@+id/tvNetMs" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Net MS: ---" android:textColor="#90B8D8" android:textSize="13sp" android:layout_marginTop="4dp"/>
                <TextView android:id="@+id/tvJahezMs" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Jahez MS: ---" android:textColor="#90B8D8" android:textSize="14sp" android:textStyle="bold"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tvDl" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Down: ---" android:textColor="#00FF88" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvUl" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Up: ---" android:textColor="#00B4FF" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- PROTECTION CARD -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#080E18" android:padding="12dp" android:orientation="vertical" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PROTECTION" android:textColor="#4070A0" android:textSize="10sp" android:letterSpacing="0.15"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tvWakelock" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Wakelock: ---" android:textColor="#90B8D8" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvGps" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="GPS: ---" android:textColor="#90B8D8" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:id="@+id/tvKeepalive" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="KA: ---" android:textColor="#90B8D8" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvBgdata" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="BG: ---" android:textColor="#90B8D8" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:background="#0A1628" android:orientation="horizontal">
        <Button android:id="@+id/btnAppList" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Apps" android:textColor="#00B4FF" android:textSize="12sp" android:background="@android:color/transparent"/>
        <Button android:id="@+id/btnTweaks" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Tweaks" android:textColor="#00B4FF" android:textSize="12sp" android:background="@android:color/transparent"/>
        <Button android:id="@+id/btnSettings" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Settings" android:textColor="#00B4FF" android:textSize="12sp" android:background="@android:color/transparent"/>
    </LinearLayout>

    <!-- LOG -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="LIVE LOG" android:textColor="#4070A0" android:textSize="9sp"
        android:paddingStart="8dp" android:paddingTop="2dp"/>
    <ScrollView android:id="@+id/scrollLog" android:layout_width="match_parent" android:layout_height="120dp"
        android:background="#080E18" android:padding="6dp">
        <LinearLayout android:id="@+id/logContainer" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>

</LinearLayout>
